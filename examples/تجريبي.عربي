# ملف تجريبي للغة عربي

# تعريف متغيرات
س = 9
ص = 5
اطبع("القيم: ", س, ص)

# عمليات حسابية
نتيجة = س + ص * 2
اطبع("النتيجة: ", نتيجة)

# شرط
اذا س > ص:
    اطبع("س أكبر من ص")
والا:
    اطبع("س ليست أكبر من ص")

# حلقة
لكل ب في مدى(5):
    اطبع("الرقم: ", ب)

# دالة
دالة جمع(أ، ب):
    ارجع أ + ب

اطبع("جمع: ", جمع(3, 4))

# صنف
صنف شخص:
    دالة __تهيئة__(هذا, اسم):
        هذا.الاسم = اسم

    دالة __عرض__(هذا):
        ارجع هذا.الاسم

شخص1 = شخص("محمد")
اطبع("الاسم: ", شخص1)
