class Point(x، y):
    def __init__(self، x، y):
        self.x = x
        self.y = y
    def area(self):
        return self.x * self.y

p1 = Point(5، 3)
assert(p1.x == 5)
assert(p1.y == 3)
assert(p1.area() == 15)

class Rect(a، b):
    def __init__(self، a، b):
        self.a = a
        self.b = b
    def area(self):
        return self.a * self.b

r1 = Rect(4، 6)
assert(r1.a == 4)
assert(r1.b == 6)
assert(r1.area() == 24)

class Account:
    def __init__(self):
        self._balance = 1000
    def balance(self):
        return self._balance

acc = Account()
assert(acc.balance() == 1000)

print("7. Classes OK")
