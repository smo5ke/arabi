assert(10 + 5 == 15)
assert(10 - 5 == 5)
assert(10 * 5 == 50)
assert(10 / 2 == 5.0)
assert(10 % 3 == 1)
assert(2 ^ 10 == 1024)
assert(2 ^ 0 == 1)
assert(10 \ 3 == 3)
assert(-5 + 3 == -2)
assert(10 * -2 == -20)
assert(3.5 + 2.5 == 6.0)
assert(10 / 3 > 3.33)
assert(2.5 * 4 == 10.0)

x = 10
x += 5
assert(x == 15)
x -= 3
assert(x == 12)
x *= 2
assert(x == 24)
x /= 4
assert(x == 6.0)

print("2. Arithmetic OK")
