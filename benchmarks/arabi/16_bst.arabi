اطبع("--- اختبار السرعة: شجرة البحث الثنائية والذاكرة العميقة ---")
بدء = الوقت()

حجم_البيانات = 10000
نجاح = اختبار_شجرة_ثنائية(حجم_البيانات - 1)

الوقت_النهاية = الوقت()
وقت_مستغرق = الوقت_النهاية - بدء

اطبع("تم إدخال وبحث عن", حجم_البيانات - 1، "عقدة.")
اطبع("عمليات البحث الناجحة:", نجاح)
اطبع("الوقت المستغرق (مللي ثانية):", وقت_مستغرق)
